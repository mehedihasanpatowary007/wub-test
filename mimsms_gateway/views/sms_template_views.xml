<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= LIST VIEW ================= -->
    <record id="view_sms_template_list" model="ir.ui.view">
        <field name="name">sms.template.list</field>
        <field name="model">sms.template</field>
        <field name="arch" type="xml">
            <list string="SMS Templates">
                <field name="name"/>
                <field name="model_id"/>
                <field name="usage_count"/>
                <field name="last_used"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_sms_template_form" model="ir.ui.view">
        <field name="name">sms.template.form</field>
        <field name="model">sms.template</field>
        <field name="arch" type="xml">
            <form string="SMS Template">

                <header>
                    <button name="action_test_template"
                            string="Test Template"
                            type="object"
                            class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_id"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="model" invisible="1"/>
                        </group>

                        <group>
                            <field name="active"/>
                            <field name="usage_count" readonly="1"/>
                            <field name="last_used" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Message Body">
                            <group>
                                <field name="body"
                                       widget="text"
                                       nolabel="1"
                                       placeholder="Example: Hello {{name}}, welcome to {{company_id.name}}!"/>

                                <separator string="Dynamic Fields Guide"/>

                                <div class="alert alert-info o_form_sheet_bg" role="alert">
                                    <h5><i class="fa fa-info-circle"/> How to Use Dynamic Fields</h5>
                                    <p class="mb-2">Dynamic fields are automatically replaced with actual data when sending SMS.</p>
                                    
                                    <strong>Supported Syntaxes:</strong>
                                    <ul class="mb-2">
                                        <li><code>{{field_name}}</code> - Recommended format</li>
                                        <li><code>{{object.field_name}}</code> - Alternative format (also works)</li>
                                        <li><code>{{related_field.name}}</code> - For related fields</li>
                                    </ul>

                                    <strong>Common Examples by Model:</strong>
                                    
                                    <div class="mt-2">
                                        <strong>For Contacts (res.partner):</strong><br/>
                                        <code>{{name}}</code> - Contact name<br/>
                                        <code>{{email}}</code> - Email address<br/>
                                        <code>{{phone}}</code> - Phone number<br/>
                                        <code>{{mobile}}</code> - Mobile number<br/>
                                    </div>

                                    <div class="mt-2">
                                        <strong>For Leads (crm.lead):</strong><br/>
                                        <code>{{name}}</code> - Lead/Opportunity name<br/>
                                        <code>{{partner_name}}</code> - Customer name<br/>
                                        <code>{{email_from}}</code> - Email<br/>
                                        <code>{{phone}}</code> - Phone number<br/>
                                        <code>{{user_id.name}}</code> - Salesperson name<br/>
                                    </div>

                                    <div class="mt-2">
                                        <strong>For Sales Orders (sale.order):</strong><br/>
                                        <code>{{name}}</code> - Order reference<br/>
                                        <code>{{partner_id.name}}</code> - Customer name<br/>
                                        <code>{{amount_total}}</code> - Total amount<br/>
                                        <code>{{date_order}}</code> - Order date<br/>
                                    </div>

                                    <div class="mt-3">
                                        <strong>Sample Template:</strong><br/>
                                        <code>Hi {{name}}, Special offer just for you! Get 20% off on our services. Valid till month end. Contact us now!</code>
                                    </div>
                                </div>

                                <separator string="Template Preview"/>
                                <field name="sample_preview" 
                                       readonly="1" 
                                       widget="text"
                                       placeholder="Save the template to see a preview with sample data"/>
                            </group>
                        </page>

                        <page string="Usage Statistics">
                            <group>
                                <group>
                                    <field name="usage_count" readonly="1"/>
                                    <field name="last_used" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    
    <!-- ================= ACTION ================= -->
    <record id="action_sms_template" model="ir.actions.act_window">
        <field name="name">SMS Templates</field>
        <field name="res_model">sms.template</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first SMS Template
            </p>
            <p>
                SMS Templates allow you to send personalized messages with dynamic content.<br/>
                Use <code>{{field_name}}</code> to insert dynamic values from your records.
            </p>
        </field>
    </record>

    <!-- ================= MENU ITEM ================= -->
    <!-- Add this to your main menu structure -->
    <!-- 
    <menuitem id="menu_sms_template"
              name="SMS Templates"
              parent="your_parent_menu_id"
              action="action_sms_template"
              sequence="10"/>
    -->

</odoo>
